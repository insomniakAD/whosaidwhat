{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whosaidwhat",
  "version": "0.1.0",
  "identifier": "com.whosaidwhat.app",
  "mainBinaryName": "whosaidwhat-app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "whosaidwhat",
        "width": 1160,
        "height": 780,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://ipc.localhost https://ipc.localhost ipc:; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
